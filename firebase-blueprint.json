{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Potential customer lead",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "pincode": { "type": "string" },
        "status": { "type": "string" },
        "value": { "type": "number" },
        "source": { "type": "string" },
        "assignedTo": { "type": "string" },
        "assignedToId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "ltv": { "type": "number" }
      },
      "required": ["name", "status", "assignedToId", "phone"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Product in stock",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "price": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "sku", "stock", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "leadId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "commission": { "type": "number" },
        "assignedToId": { "type": "string" },
        "trackingId": { "type": "string" },
        "courierPartner": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "product", "quantity", "status", "total"]
    },
    "Task": {
      "title": "Task",
      "description": "Sales tasks and refills",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "leadId": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["title", "userId", "dueDate"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System activity logs",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "entityId": { "type": "string" },
        "entityType": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Sales leads collection"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Product inventory collection"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders collection"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks for refills and callbacks"
    },
    "/logs/{logId}": {
      "schema": "AuditLog",
      "description": "Security audit logs"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Staff account data"
    }
  }
}
