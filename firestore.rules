rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tzsupportayurveda@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }

    function isSales() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Sales', 'Marketer', 'Manager'])
      );
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // 2. Leads
    match /leads/{leadId} {
      function canReadLead() {
        let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
        return isAdmin() || 
               userRole in ['Marketer', 'Manager', 'Inventory', 'Delivery'] ||
               resource.data.assignedToId == request.auth.uid ||
               resource.data.status == 'New Lead';
      }

      allow read: if isStaff() && canReadLead();
      
      allow create: if isStaff() && 
        request.resource.data.keys().hasAll(['name', 'status', 'assignedToId', 'phone', 'createdAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.phone is string && request.resource.data.phone.size() <= 20;

      allow update: if isStaff() && (
        isAdmin() ||
        (resource.data.assignedToId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'updatedAt', 'ltv', 'history', 'product', 'quantity', 'address', 'city', 'pincode', 'name', 'phone', 'email']))
      );
      allow delete: if isAdmin();
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if hasRole('Inventory') || isAdmin();
    }

    // 4. Orders
    match /orders/{orderId} {
      function canReadOrder() {
        return isAdmin() || 
               hasRole('Manager') || 
               hasRole('Inventory') || 
               hasRole('Delivery') || 
               hasRole('Marketer') ||
               resource.data.assignedToId == request.auth.uid;
      }
      allow read: if isStaff() && canReadOrder();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // 5. Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSales();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 6. Logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
