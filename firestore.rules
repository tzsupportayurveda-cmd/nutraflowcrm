rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tzsupportayurveda@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }

    function isSales() {
      return isSignedIn() && (
        request.auth.token.email == 'tzsupportayurveda@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Sales', 'Marketer', 'Manager', 'Admin'])
      );
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.email == 'tzsupportayurveda@gmail.com' ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        (request.auth.token.email == 'tzsupportayurveda@gmail.com' && role == 'Admin') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role)
      );
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // 2. Leads
    match /leads/{leadId} {
      function canReadLead() {
        return request.auth.token.email == 'tzsupportayurveda@gmail.com' || 
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Marketer', 'Manager', 'Inventory', 'Delivery'] ||
                 (resource != null && resource.data.assignedToId == request.auth.uid) ||
                 (resource != null && resource.data.status == 'New Lead' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Sales')
               ));
      }

      allow read: if canReadLead();
      
      allow create: if isStaff() && 
        request.resource.data.keys().hasAll(['name', 'status', 'assignedToId', 'phone', 'createdAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.phone is string && request.resource.data.phone.size() <= 20;

      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource != null && resource.data.assignedToId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly([
           'status', 'notes', 'updatedAt', 'ltv', 'history', 'product', 
           'quantity', 'address', 'city', 'pincode', 'name', 'phone', 
           'email', 'callbackTime', 'isArchived', 'assignedToId', 'assignedTo', 
           'paymentMode', 'source', 'serialId', 'affiliateId'
         ])) ||
        (resource != null && (resource.data.assignedToId == "" || resource.data.assignedToId == "unassigned") &&
         incoming().diff(existing()).affectedKeys().hasOnly(['assignedToId', 'assignedTo', 'updatedAt', 'history']))
      );
      allow delete: if isAdmin();
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if hasRole('Inventory') || isAdmin();
    }

    // 4. Orders
    match /orders/{orderId} {
      function canReadOrder() {
        return isAdmin() || 
               hasRole('Manager') || 
               hasRole('Inventory') || 
               hasRole('Delivery') || 
               hasRole('Marketer') ||
               resource.data.assignedToId == request.auth.uid;
      }
      allow read: if isStaff() && canReadOrder();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // 5. Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSales();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 6. Logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // 7. Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn(); // System or agent can create/update
    }

    // 8. Metadata (Counters)
    match /metadata/{id} {
      allow read, write: if isStaff();
    }
  }
}
