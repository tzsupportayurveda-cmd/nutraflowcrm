rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tzsupportayurveda@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin')
      );
    }

    function isSales() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Sales' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    function isInventory() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Inventory' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // 2. Leads
    match /leads/{leadId} {
      function canReadLead() {
        return isAdmin() || 
               resource.data.assignedToId == request.auth.uid ||
               resource.data.status == 'New Lead';
      }

      allow read: if isSales() && canReadLead();
      
      allow create: if isSales() && 
        request.resource.data.keys().hasAll(['name', 'status', 'assignedToId', 'phone', 'createdAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.phone is string && request.resource.data.phone.size() <= 20;

      allow update: if isSales() && (
        isAdmin() ||
        (resource.data.assignedToId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'updatedAt', 'ltv', 'history', 'product', 'quantity', 'address', 'city', 'pincode', 'name', 'phone', 'email']))
      );
      allow delete: if isAdmin();
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 3. Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isInventory();
    }

    // 4. Orders
    match /orders/{orderId} {
      allow read: if isSales();
      allow create: if isSales() && 
        request.resource.data.keys().hasAll(['customerId', 'items', 'status', 'total']);
      allow update: if isSales();
      allow delete: if isAdmin();
    }
  }
}
